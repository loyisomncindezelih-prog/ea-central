<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#0A1628" />
            <stroke android:width="2dp" android:color="#1E90FF" />
        </shape>
    </item>
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40"
                android:startColor="#1E3A8A"
                android:endColor="#000814" />
        </shape>
    </item>
</layer-list>
